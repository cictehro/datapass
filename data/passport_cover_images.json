    "480p": "",
    "768p": "'use client';\n\nimport { useEffect, useState } from 'react';\nimport { Button } from '@/components/ui/Button';\nimport { Input, Label } from '@/components/ui/Input';\nimport { FlagImg } from '@/components/FlagImg';\nimport { ChevronDownIcon, ClipboardPasteIcon, CopyIcon, PlusIcon } from '@/components/icons';\nimport { DEFAULT_RESOLUTION_KEYS, validateNewFieldKey } from '@/lib/images';\nimport { cn } from '@/lib/utils';\nimport { useImages } from '@/components/providers/ImagesProvider';\nimport { useStore } from '@/components/providers/StoreProvider';\nimport { ImagePreview } from './ImagePreview';\n\nconst STANDARD_KEYS = new Set<string>(DEFAULT_RESOLUTION_KEYS);\n\nfunction SavingSpinner() {\n  return (\n    <span className=\"h-3 w-3 flex-shrink-0 animate-spin rounded-full border-2 border-muted/30 border-t-muted\" />\n  );\n}\n\nfunction FieldRow({ code, fieldKey }: { code: string; fieldKey: string }) {\n  const { state, saveField, removeFieldKey, isSaving } = useImages();\n  const savedValue = state.data[code]?.[fieldKey] ?? '';\n  const [value, setValue] = useState(savedValue);\n  const [errorMsg, setErrorMsg] = useState<string | null>(null);\n  const [copied, setCopied] = useState(false);\n  const savingKey = `field:${code}:${fieldKey}`;\n  const saving = isSaving(savingKey);\n  const isCustomKey = !STANDARD_KEYS.has(fieldKey);\n\n  // Re-sync the local input once a successful save updates the server-echoed\n  // value. Never clobbers the user's text on failure — failures only set\n  // errorMsg, they don't touch `value`.\n  useEffect(() => {\n    setValue(savedValue);\n    // eslint-disable-next-line react-hooks/exhaustive-deps\n  }, [savedValue]);\n\n  async function commit(nextValue: string) {\n    if (nextValue === savedValue) return;\n    setErrorMsg(null);\n    const result = await saveField(code, fieldKey, nextValue);\n    if (!result.ok) setErrorMsg(result.error ?? 'Save failed — reload and try again');\n  }\n\n  // Paste always replaces the field's current content with clipboard text\n  // (functionally \"clear then paste\" when something's already there) and\n  // saves instantly, same as any other edit.\n  async function handlePaste() {\n    try {\n      const text = await navigator.clipboard.readText();\n      setValue(text);\n      await commit(text);\n    } catch {\n      setErrorMsg('Clipboard paste unavailable — check browser permissions and paste manually.');\n    }\n  }\n\n  async function handleCopy() {\n    try {\n      await navigator.clipboard.writeText(value);\n      setCopied(true);\n      setTimeout(() => setCopied(false), 1500);\n    } catch {\n      setErrorMsg('Copy failed — check browser permissions.');\n    }\n  }\n\n  return (\n    <div className=\"space-y-1\">\n      <div className=\"flex items-center gap-1.5\">\n        <span className=\"w-16 flex-shrink-0 truncate font-mono text-xs text-muted\" title={fieldKey}>\n          {fieldKey}\n        </span>\n        <div className=\"relative flex-1\">\n          <Input\n            value={value}\n            onChange={(e) => setValue(e.target.value)}\n            onBlur={() => commit(value)}\n            onKeyDown={(e) => {\n              if (e.key === 'Enter') (e.target as HTMLInputElement).blur();\n            }}\n            placeholder=\"https://…\"\n            className=\"pr-7 font-mono text-xs\"\n          />\n          {saving && (\n            <span className=\"absolute right-2.5 top-1/2 -translate-y-1/2\">\n              <SavingSpinner />\n            </span>\n          )}\n        </div>\n        <button\n          type=\"button\"\n          title={value ? 'Clear then paste from clipboard' : 'Paste from clipboard'}\n          onClick={handlePaste}\n          className=\"flex-shrink-0 text-muted hover:text-text\"\n        >\n          <ClipboardPasteIcon size={13} />\n        </button>\n        {value && (\n          <button\n            type=\"button\"\n            title={copied ? 'Copied!' : 'Copy link address'}\n            onClick={handleCopy}\n            className={cn('flex-shrink-0', copied ? 'text-success' : 'text-muted hover:text-text')}\n          >\n            <CopyIcon size={13} />\n          </button>\n        )}\n        {value && (\n          <button\n            type=\"button\"\n            title=\"Clear this field's value (keeps the key)\"\n            onClick={() => {\n              setValue('');\n              commit('');\n            }}\n            className=\"flex-shrink-0 whitespace-nowrap text-xs text-muted hover:text-danger\"\n          >\n            Clear\n          </button>\n        )}\n        {isCustomKey && (\n          <button\n            type=\"button\"\n            title=\"Remove this key entirely\"\n            onClick={() => removeFieldKey(code, fieldKey).then((r) => !r.ok && setErrorMsg(r.error ?? 'Remove failed'))}\n            className=\"flex-shrink-0 whitespace-nowrap text-xs text-muted hover:text-danger\"\n          >\n            Remove key\n          </button>\n        )}\n      </div>\n      {errorMsg && (\n        <p className=\"pl-[68px] text-xs text-danger\">\n          {errorMsg}{' '}\n          <button type=\"button\" className=\"underline\" onClick={() => commit(value)}>\n            Retry\n          </button>\n        </p>\n      )}\n    </div>\n  );\n}\n\nexport function CountryImageCard({ code }: { code: string }) {\n  const { state, addField, deleteCountry, isSaving } = useImages();\n  const { state: mainState } = useStore();\n  const [expanded, setExpanded] = useState(false);\n  const [addingField, setAddingField] = useState(false);\n  const [newKey, setNewKey] = useState('');\n  const [newKeyValue, setNewKeyValue] = useState('');\n  const [newKeyError, setNewKeyError] = useState<string | null>(null);\n  const [confirmingDelete, setConfirmingDelete] = useState(false);\n  const [confirmToken, setConfirmToken] = useState('');\n  const [confirmError, setConfirmError] = useState<string | null>(null);\n\n  const entry = state.data[code] ?? {};\n  const name = state.countries[code] ?? code;\n  const fieldKeys = Object.keys(entry);\n  const deleting = isSaving(`country:${code}`);\n\n  async function handleAddField() {\n    const check = validateNewFieldKey(newKey, fieldKeys);\n    if (!check.valid) {\n      setNewKeyError(check.error);\n      return;\n    }\n    const result = await addField(code, newKey.trim(), newKeyValue);\n    if (result.ok) {\n      setAddingField(false);\n      setNewKey('');\n      setNewKeyValue('');\n      setNewKeyError(null);\n    } else {\n      setNewKeyError(result.error ?? 'Save failed');\n    }\n  }\n\n  function openDeleteConfirm() {\n    setConfirmingDelete(true);\n    setConfirmToken('');\n    setConfirmError(null);\n  }\n\n  function cancelDeleteConfirm() {\n    setConfirmingDelete(false);\n    setConfirmToken('');\n    setConfirmError(null);\n  }\n\n  // Destructive + irreversible, so this requires re-typing the connected\n  // GitHub token (checked against the one already validated in the main\n  // store) as well as the explicit confirm click — a plain double-click\n  // confirm isn't enough friction for permanently deleting a country entry.\n  async function handleConfirmDelete() {\n    if (confirmToken !== mainState.token) {\n      setConfirmError('Token does not match the connected account — re-enter it to confirm.');\n      return;\n    }\n    const result = await deleteCountry(code);\n    if (result.ok) {\n      cancelDeleteConfirm();\n    } else {\n      setConfirmError(result.error ?? 'Delete failed');\n    }\n  }\n\n  return (\n    <div className=\"rounded border border-border bg-surface2\">\n      <button\n        type=\"button\"\n        onClick={() => setExpanded((e) => !e)}\n        className=\"flex w-full items-center gap-2.5 px-3 py-2.5 text-left text-sm\"\n      >\n        <FlagImg code={code} size=\"w20\" />\n        <span className=\"flex-1 truncate\">{name}</span>\n        <span className=\"font-mono text-xs text-muted\">{code}</span>\n        <ImagePreview entry={entry} compact />\n        <ChevronDownIcon className={cn('flex-shrink-0 text-muted transition-transform', expanded && 'rotate-180')} />\n      </button>\n\n      {expanded && (\n        <div className=\"space-y-3 border-t border-border px-3 py-3\">\n          {fieldKeys.length > 0 ? (\n            <div className=\"space-y-2\">\n              {fieldKeys.map((key) => (\n                <FieldRow key={key} code={code} fieldKey={key} />\n              ))}\n            </div>\n          ) : (\n            <p className=\"text-xs text-muted\">No resolution fields yet.</p>\n          )}\n\n          {!addingField ? (\n            <Button variant=\"ghost\" size=\"sm\" onClick={() => setAddingField(true)}>\n              <PlusIcon size={11} />\n              Add field\n            </Button>\n          ) : (\n            <div className=\"space-y-1.5 rounded border border-border bg-surface px-2.5 py-2\">\n              <div className=\"flex flex-wrap gap-1.5\">\n                <Input\n                  value={newKey}\n                  onChange={(e) => {\n                    setNewKey(e.target.value);\n                    setNewKeyError(null);\n                  }}\n                  placeholder=\"key, e.g. 4k\"\n                  className=\"min-w-[90px] flex-1 text-xs\"\n                />\n                <Input\n                  value={newKeyValue}\n                  onChange={(e) => setNewKeyValue(e.target.value)}\n                  placeholder=\"https://… (optional)\"\n                  className=\"min-w-[140px] flex-[2] text-xs\"\n                />\n              </div>\n              <div className=\"flex gap-1.5\">\n                <Button\n                  variant=\"primary\"\n                  size=\"sm\"\n                  loading={isSaving(`field:${code}:${newKey.trim()}`)}\n                  onClick={handleAddField}\n                >\n                  Save\n                </Button>\n                <Button\n                  variant=\"ghost\"\n                  size=\"sm\"\n                  onClick={() => {\n                    setAddingField(false);\n                    setNewKey('');\n                    setNewKeyValue('');\n                    setNewKeyError(null);\n                  }}\n                >\n                  Cancel\n                </Button>\n              </div>\n              {newKeyError && <p className=\"text-xs text-danger\">{newKeyError}</p>}\n            </div>\n          )}\n\n          <div className=\"border-t border-border pt-3\">\n            {!confirmingDelete ? (\n              <Button variant=\"danger\" size=\"sm\" onClick={openDeleteConfirm}>\n                Delete country entry\n              </Button>\n            ) : (\n              <div className=\"space-y-2 rounded border border-danger/40 bg-surface px-2.5 py-2\">\n                <p className=\"text-xs text-danger\">\n                  This permanently deletes the entry for <span className=\"font-mono\">{code}</span>. This cannot be\n                  undone.\n                </p>\n                <div>\n                  <Label>Re-enter your GitHub token to confirm</Label>\n                  <Input\n                    type=\"password\"\n                    value={confirmToken}\n                    autoComplete=\"off\"\n                    placeholder=\"ghp_…\"\n                    className=\"font-mono text-xs\"\n                    onChange={(e) => {\n                      setConfirmToken(e.target.value);\n                      setConfirmError(null);\n                    }}\n                  />\n                </div>\n                {confirmError && <p className=\"text-xs text-danger\">{confirmError}</p>}\n                <div className=\"flex gap-1.5\">\n                  <Button\n                    variant=\"danger\"\n                    size=\"sm\"\n                    loading={deleting}\n                    disabled={!confirmToken}\n                    onClick={handleConfirmDelete}\n                  >\n                    Confirm delete\n                  </Button>\n                  <Button variant=\"ghost\" size=\"sm\" onClick={cancelDeleteConfirm}>\n                    Cancel\n                  </Button>\n                </div>\n              </div>\n            )}\n          </div>\n        </div>\n      )}\n    </div>\n  );\n}\n",
    "1024p": "",
    "2048p": "",
    "6k": ""
  },
